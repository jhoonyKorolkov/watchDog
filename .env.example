# ==========================================
# WatchDog Environment Variables Template
# ==========================================
# Скопируйте этот файл в .env и заполните значениями

# ==========================================
# ОБЯЗАТЕЛЬНЫЕ ПЕРЕМЕННЫЕ
# ==========================================

# Session secret для nuxt-auth-utils
# Генерация: openssl rand -base64 32
NUXT_SESSION_PASSWORD=change-this-to-random-32-char-string

# Пароль администратора для входа в систему
ADMIN_PASSWORD=admin123
# ==========================================
# НАСТРОЙКИ БАЗЫ ДАННЫХ (опционально)
# ==========================================

# Путь к SQLite базе (по умолчанию .data/sqlite.db)
# Для локальной разработки: НЕ МЕНЯЙТЕ это значение!
# Для Docker: переменная автоматически устанавливается в docker-compose.yml
# DATABASE_URL=.data/sqlite.db

# ==========================================
# НАСТРОЙКИ МОНИТОРИНГА (опционально)
# ==========================================

# Включить/выключить автоматический мониторинг
# По умолчанию: true (включен)
MONITOR_ENABLED=true

# Расписание проверок в формате cron (минута час день месяц день_недели)
# По умолчанию: */1 * * * * (каждую минуту)
# Примеры:
#   */5 * * * * - каждые 5 минут
#   0 * * * *   - каждый час
#   0 0 * * *   - каждый день в полночь
MONITOR_SCHEDULE=*/1 * * * *
# ==========================================
# TELEGRAM NOTIFICATIONS (опционально)
# ==========================================

# Telegram Bot Token
# Получить: @BotFather в Telegram
# Формат: 123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_BOT_TOKEN=

# Telegram Chat ID
# Узнать: запустите бот и используйте GET /api/telegram/get-chat-id
# Формат: 123456789 или -100123456789 (для групп)
TELEGRAM_CHAT_ID=

# ==========================================
# НАСТРОЙКИ ПРИЛОЖЕНИЯ (опционально)
# ==========================================

# Порт приложения (по умолчанию 3000)
PORT=3000

# Node окружение
NODE_ENV=production
